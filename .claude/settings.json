{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(gh api:*)",
      "Bash(gh pr:*)",
      "Bash(gh issue:*)",
      "Bash(gh release:*)",
      "Bash(gh milestone:*)",
      "Bash(uv lock:*)",
      "Bash(uv sync:*)",
      "Bash(uv run:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm update:*)",
      "Bash(pnpm outdated:*)",
      "Bash(pnpm list:*)",
      "Bash(pnpm exec:*)",
      "Bash(pnpm tsc:*)",
      "Bash(pnpm build:*)",
      "Bash(npm view:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/sync-locks.py"
          }
        ]
      }
    ]
  }
}
