# Global options
{
	skip_install_trust
	http_port 8181
	https_port 8282
}

# Site configuration
https://{$FQDN:localhost}, http://{$FQDN:localhost} {

	root * /srv

	encode gzip

	header {
		X-Frame-Options SAMEORIGIN
		X-Content-Type-Options nosniff
		X-XSS-Protection "1; mode=block"
	}

	# Proxy API requests to backend
	handle /api/v1* {
		reverse_proxy {$BACKEND_URL}
	}

	# Proxy uploads to backend
	handle /uploads/* {
		reverse_proxy {$BACKEND_URL}
	}

	# Proxy Keycloak authentication endpoints and resources
	handle /realms/* {
		reverse_proxy {$KEYCLOAK_INTERNAL_URL}
	}

	handle /resources/* {
		reverse_proxy {$KEYCLOAK_INTERNAL_URL}
	}

	handle /js/* {
		reverse_proxy {$KEYCLOAK_INTERNAL_URL}
	}

	# Keycloak admin REST API
	handle /admin/* {
		reverse_proxy {$KEYCLOAK_INTERNAL_URL}
	}

	# Convenience redirect: /auth or /auth/* → Keycloak admin console
	redir /auth /admin/master/console
	redir /auth/* /admin/master/console

	# Serve static frontend files with SPA fallback
	handle {
		try_files {path} /index.html
		file_server
	}
}