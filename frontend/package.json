    "@angular/core": "^21.2.7",
    "@angular/forms": "^21.2.7",
    "@angular/material": "^21.2.5",
    "@angular/platform-browser": "^21.2.7",
    "@angular/router": "^21.2.7",
    "@fontsource/roboto": "^5.2.10",
    "@maplibre/ngx-maplibre-gl": "^21.0.2",
    "angular-auth-oidc-client": "^21.0.1",
