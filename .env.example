# =============================================================================
# StickerMap Environment Configuration
# Copy this file to .env and adjust values as needed
# =============================================================================

# =============================================================================
# Database Configuration (DB_* pattern - vendor agnostic)
# =============================================================================
DB_HOST=postgis
DB_PORT=5432
DB_DBNAME=stickermap
DB_USER=user
DB_PASSWORD=password

# =============================================================================
# Keycloak Configuration
# =============================================================================

# External URL - used by browsers to authenticate (must match JWT issuer)
KEYCLOAK_URL=https://localhost:8282

# Internal URL - used by backend for container-to-container JWKS fetching
# Only needed in containerized environments; defaults to KEYCLOAK_URL if not set
KEYCLOAK_INTERNAL_URL=http://keycloak:8080

# Realm and client settings
KEYCLOAK_REALM=stickermap
KEYCLOAK_CLIENT_ID=stickermap-client
KEYCLOAK_CLIENT_SECRET=clientsecret

# Admin credentials (for keycloak container setup)
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=admin

# =============================================================================
# Service URLs & Ports
# =============================================================================

# Backend API
BACKEND_URL=http://backend:5555
BACKEND_PORT=5555

# Frontend
FQDN=localhost
TILESERVER_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png

# =============================================================================
# Backend-specific Settings
# =============================================================================

# File storage
UPLOAD_DIR=/app/uploads

# CORS Configuration (comma-separated lists, use * for all)
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=*
CORS_ALLOWED_HEADERS=*
CORS_ALLOW_CREDENTIALS=true

# Backend logging level (debug, info, warning, error)
LOG_LEVEL=info

# =============================================================================
# Production Settings (examples - uncomment and modify for production)
# =============================================================================
# PRODCUTION=true
# DB_PASSWORD=<strong-random-password>
# KEYCLOAK_ADMIN_PASSWORD=<strong-random-password>
# KEYCLOAK_CLIENT_SECRET=<strong-random-secret>
# KEYCLOAK_URL=https://keycloak.yourdomain.com
